generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
  MEMBER
}

enum DocumentCategory {
  BIBLE_STUDY
  BULLETIN
  SERMON_NOTES
  NEWSLETTER
  OTHER
}

enum DocumentVisibility {
  PUBLIC
  MEMBERS_ONLY
  ADMIN_ONLY
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(VIEWER)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pages         Page[]
  blogPosts     BlogPost[]
  events        Event[]
  memberProfile        MemberProfile?
  memberAnnouncements  MemberAnnouncement[]
  documents            Document[]

  @@map("users")
}

model Page {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  content       String     @db.Text
  excerpt       String?
  featuredImage String?
  status        PageStatus @default(DRAFT)
  sortOrder     Int        @default(0)
  showInNav     Boolean    @default(false)
  parentId      String?
  parent        Page?      @relation("PageChildren", fields: [parentId], references: [id])
  children      Page[]     @relation("PageChildren")
  authorId      String
  author        User       @relation(fields: [authorId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("pages")
}

model BlogPost {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  content       String     @db.Text
  excerpt       String?
  featuredImage String?
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?
  scheduledAt   DateTime?
  tags          Json       @default("[]")
  authorId      String
  author        User       @relation(fields: [authorId], references: [id])
  socialPosts   SocialPost[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("blog_posts")
}

model Event {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  description   String      @db.Text
  location      String?
  address       String?
  startDate     DateTime
  endDate       DateTime?
  allDay        Boolean     @default(false)
  recurring       String?
  recurringDays   String?
  recurringTime   String?
  recurringEndTime String?
  featuredImage   String?
  status        EventStatus @default(UPCOMING)
  category      String?
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("events")
}

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  subject     String
  message     String   @db.Text
  read        Boolean  @default(false)
  replied     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("contact_submissions")
}

model VimeoVideo {
  id          String   @id @default(cuid())
  vimeoId     String   @unique
  title       String
  description String?  @db.Text
  thumbnail   String?
  publishedAt DateTime
  channelId   String
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("vimeo_videos")
}

model SocialPost {
  id          String    @id @default(cuid())
  platform    String
  content     String    @db.Text
  postUrl     String?
  postedAt    DateTime?
  status      String    @default("pending")
  blogPostId  String?
  blogPost    BlogPost? @relation(fields: [blogPostId], references: [id])
  createdAt   DateTime  @default(now())

  @@map("social_posts")
}

model Media {
  id          String   @id @default(cuid())
  filename    String
  url         String
  mimeType    String
  size        Int
  alt         String?
  caption     String?
  aiGenerated Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("media")
}

model SiteSettings {
  id          String @id @default("default")
  churchName  String @default("Calvary Lutheran Church")
  tagline     String @default("Grow in the grace and knowledge of our Lord and Savior Jesus Christ.")
  email       String @default("")
  phone       String @default("")
  address     String @default("")
  logoUrl     String @default("")
  heroImageUrl String @default("")
  vimeoUserId String @default("")
  facebookUrl String @default("")
  instagramUrl String @default("")
  gaTrackingId String @default("")
  gaPropertyId String @default("")
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

model HomepageContent {
  id               String   @id @default("default")
  heroSection      Json     @default("{}")
  serviceSection   Json     @default("{}")
  highlightSection Json     @default("{}")
  sermonSection    Json     @default("{}")
  ctaSection       Json     @default("{}")
  customSections   Json     @default("[]")
  updatedAt        DateTime @updatedAt

  @@map("homepage_content")
}

model MemberProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String?
  address     String?
  birthday    DateTime?
  photoUrl    String?
  bio         String?   @db.Text
  family      String?
  joinDate    DateTime?
  isVisible   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("member_profiles")
}

model MemberAnnouncement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("member_announcements")
}

model Document {
  id          String             @id @default(cuid())
  title       String
  description String?            @db.Text
  filename    String
  url         String
  mimeType    String
  size        Int
  category    DocumentCategory   @default(OTHER)
  visibility  DocumentVisibility @default(PUBLIC)
  publishedAt DateTime?
  authorId    String
  author      User               @relation(fields: [authorId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("documents")
}
